# ==============================================================================
# Environment Configuration Template (Copy this to .env and adjust)
# ==============================================================================

# Application Metadata
PROJECT_NAME="AI Data Engineering Copilot"
PROJECT_DESCRIPTION="Backend API for connecting to PostgreSQL databases, discovering their schemas, and exploring tables, columns, and relationships through a searchable metadata catalog."
VERSION="0.1.0"
ENVIRONMENT="development"

# Server Bind Address & Port
HOST="0.0.0.0"
PORT=8000

# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/copilot_db"

# Security — Fernet key encrypting stored target-database passwords at rest.
# Generate your own: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY="REPLACE_WITH_YOUR_OWN_FERNET_KEY"

# Celery / Redis — async sync & refresh jobs (see app/core/celery_app.py).
# Run `docker compose up -d redis` or a local Redis instance.
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"
